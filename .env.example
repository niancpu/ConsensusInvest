# Copy this file to .env and fill only the providers you want to enable.
# .env is ignored by git.

# Server
CONSENSUSINVEST_HOST=127.0.0.1
CONSENSUSINVEST_PORT=8000
# Comma-separated local frontend origins allowed to call the API with credentials.
# Keep this explicit; wildcard origins are rejected when credentials are enabled.
CONSENSUSINVEST_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Runtime storage
# Production/default runtime uses SQLite for Evidence plus workflow/agent/report runtime state.
# The runtime path is a base path; wiring derives module DBs beside it.
CONSENSUSINVEST_EVIDENCE_STORE_BACKEND=sqlite
CONSENSUSINVEST_EVIDENCE_DB_PATH=./data/evidence_store.sqlite3
CONSENSUSINVEST_RUNTIME_DB_PATH=./data/runtime.sqlite3
CONSENSUSINVEST_SEED_DEMO_DATA=0
# Explicit local/test escape hatch. When set to 1, runtime state uses in-memory repositories.
CONSENSUSINVEST_ALLOW_IN_MEMORY_RUNTIME=0

# Real Search Providers
TAVILY_API_KEY=
EXA_API_KEY=

# Real Agent LLM via LiteLLM
# Runtime requires a real LLM provider; empty or unsupported values fail at startup.
CONSENSUSINVEST_LLM_PROVIDER=litellm
# Use the LiteLLM model string for your provider, for example openai/gpt-4.1-mini.
CONSENSUSINVEST_LLM_MODEL=
CONSENSUSINVEST_SWARM_MODEL=
CONSENSUSINVEST_JUDGE_MODEL=
CONSENSUSINVEST_LLM_TEMPERATURE=0.2
CONSENSUSINVEST_LLM_TIMEOUT_SECONDS=60

# Fill the key required by your LiteLLM model string.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Tavily options
CONSENSUSINVEST_TAVILY_SEARCH_DEPTH=basic
CONSENSUSINVEST_TAVILY_INCLUDE_RAW_CONTENT=true
CONSENSUSINVEST_TAVILY_MAX_RESULTS=5

# Exa options
CONSENSUSINVEST_EXA_SEARCH_TYPE=auto
CONSENSUSINVEST_EXA_MAX_RESULTS=5
CONSENSUSINVEST_EXA_INCLUDE_TEXT=true
CONSENSUSINVEST_EXA_INCLUDE_HIGHLIGHTS=true
