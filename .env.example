# Copy this file to .env and fill only the providers you want to enable.
# .env is ignored by git.

# Server
CONSENSUSINVEST_HOST=127.0.0.1
CONSENSUSINVEST_PORT=8000

# Real Search Providers
TAVILY_API_KEY=
EXA_API_KEY=

# Tavily options
CONSENSUSINVEST_TAVILY_SEARCH_DEPTH=basic
CONSENSUSINVEST_TAVILY_INCLUDE_RAW_CONTENT=true
CONSENSUSINVEST_TAVILY_MAX_RESULTS=5

# Exa options
CONSENSUSINVEST_EXA_SEARCH_TYPE=auto
CONSENSUSINVEST_EXA_MAX_RESULTS=5
CONSENSUSINVEST_EXA_INCLUDE_TEXT=true
CONSENSUSINVEST_EXA_INCLUDE_HIGHLIGHTS=true
